<Window x:Class="winDetail"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bgm"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen"
        Title="BGM - BaulastenGISManager 0.11" Height="866" Width="1119">
    <Window.Resources>
        <Style x:Key="dgRowStyleRB" TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource dgRowStyle}">
            <Style.Triggers>
                <!--<DataTrigger Binding="{Binding STATUS}" Value="1">
                    <Setter Property="Foreground" Value="blue" />
                    <Setter Property="ToolTip" Value="Dieser Eintrag ist eine Verlinkung mit einem Verwandten Vorgang" />
                </DataTrigger>-->
                <DataTrigger Binding="{Binding gueltig}" Value="N">
                    <Setter Property="Background" Value="Red" />
                </DataTrigger>
                <DataTrigger Binding="{Binding genese}" Value="2">
                    <Setter Property="Background" Value="Orange" />
                    <Setter Property="ToolTip" Value="Diese Objekte wurden selbst digitalisiert" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <DockPanel Background="Gray" Name="dpMain"  >
        <TabControl Margin="1">
            <TabItem   >
                <StackPanel Margin="5,5,15,5" Background="LightGray" Height="810">


                    <StackPanel Orientation="Horizontal" Margin="5"  AllowDrop="True" 
                                Name="spTop"
                                Drop="StackPanel_Drop">
                        <TextBlock Width="100" Margin="5" Padding="5" Height="30">Baulasten-BlattNr.:</TextBlock>
                        <TextBox Name="tbBaulastNr" Width="100" Margin="5" Padding="5" Height="30"></TextBox>
                        <Button Name="btnAusProbaug" Click="btnAusProbaug_Click" Width="100"
                                Content="start" Margin="5" IsDefault="True" Height="35"/>
                      
                        <StackPanel Orientation="Vertical" Width="450" Margin="5">

                            <TextBlock x:Name="tbGISinfo" Margin="0" Foreground="Red"></TextBlock>
                            <TextBlock x:Name="tbGISinfo2" Margin="0" Foreground="Red"></TextBlock>
                            <Button Name="btnBaulastLoeschen" Click="btnBaulastLoeschen_Click" Margin="5" 
                                   Background="LightGreen" Foreground="black" FontFamily="Arial Black" Height="15"
                            Width="100" HorizontalAlignment="Right" >HILFE</Button>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Name="spFST" Orientation="Vertical" Width="1300" 
                                HorizontalAlignment="Left">
                        <Border BorderBrush="Green" BorderThickness="1" Margin="5" 
                                HorizontalAlignment="Left" Width="1073">

                            <StackPanel HorizontalAlignment="Left"  Width="1293">
                                <StackPanel Orientation="Horizontal" Width="700" HorizontalAlignment="Left">

                                    <CheckBox Name="chkQuelle" IsChecked="True" Click="chkQuelle_Click" IsEnabled="False"/>
                                    <TextBlock HorizontalAlignment="Center" Margin="2" Name="tbQuelle">Belastet aus ProbauG</TextBlock>
                                    <Button Name="btnZumGISPROBAUG" Click="btnZumGISPROBAUG_Click" 
                                            Content="Flurstücke im GIS" Width="100"    
                                        Height="20"  Margin="5" HorizontalAlignment="Right"
                                            />
                                    <Button Name="btnEigentuemerProbaug" Click="btnEigentuemerProbaug_Click" Margin="5" Height="20"
                                            Width="100"  ToolTip="Zeigt die Eigentümerdaten entsprechend der Flurstücksangaben im PROBAUG"
                                            >Eigentümer</Button>
                                    <TextBlock Name="tbanzahlobjpg" Padding="5" Margin="2" 
                                                   FontStyle="Normal"   ></TextBlock>
                                    <TextBlock  Padding="5" Margin="2" 
                    FontStyle="Normal" FontFamily="Arial Black" > P R O B A U G</TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Width="1270" HorizontalAlignment="Left">

                                    <DataGrid  x:Name="dgAusProbaug"   ItemsSource="{Binding ''}"      Margin="0"                                           
                                              RowStyle="{StaticResource dgRowStyleRB}"                                        
                                              ColumnHeaderStyle="{StaticResource dgHeaderStyle}"    
                                     Width="930"   MaxHeight="160" Height="160"
                                           HorizontalAlignment="Left"
                                   >
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Gemarkung"      Binding="{Binding gemarkungstext}"     />
                                            <!--<DataGridTextColumn Header="gemnr"      Binding="{Binding gemcode}"     />-->
                                            <DataGridTextColumn Header="Flur"  Binding="{Binding flur}" />
                                            <!--<DataGridTextColumn Header="Zähler"   Binding="{Binding zaehler}" />
                                        <DataGridTextColumn Header="Nenner"   Binding="{Binding nenner}" />-->
                                            <DataGridTextColumn Header="Fst"  Binding="{Binding fstueckKombi}" />
                                            <DataGridTextColumn Header="g"  Binding="{Binding gueltig}"  ToolTipService.ToolTip="gültig" />
                                            <DataGridTextColumn Header="lNr"  Binding="{Binding gebucht}" />
                                            <DataGridTextColumn Header="AzJahr"  Binding="{Binding AzJahr}" />
                                            <!--<DataGridTextColumn Header="og"  Binding="{Binding AzOG}" />-->
                                            <DataGridTextColumn Header="AzNr"  Binding="{Binding AzNr}" />
                                            <!--<DataGridTextColumn Header="Prefix"  Binding="{Binding Prefix}" />-->
                                            <DataGridTextColumn Header="k1"  Binding="{Binding Kennziffer_1}" ToolTipService.ToolTip="Kennziffer1" />
                                            <DataGridTextColumn Header="k2"  Binding="{Binding Kennziffer_2}" ToolTipService.ToolTip="Kennziffer2" />
                                            <DataGridTextColumn Header="k3"  Binding="{Binding Kennziffer_3}" ToolTipService.ToolTip="Kennziffer3" />
                                            <DataGridTextColumn Header="k4"  Binding="{Binding Kennziffer_4}" ToolTipService.ToolTip="Kennziffer4"  />
                                            <!--<DataGridTextColumn Header="gebucht"  Binding="{Binding gebucht}" />-->
                                            <!--<DataGridTextColumn Header="fs"    Binding="{Binding FS}" />-->
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Border BorderBrush="Gray"  Margin="5" BorderThickness="2" Width="120"
                 Drop="dropTheBomb" AllowDrop="True" VerticalAlignment="Top" Height="161"
                   >
                                        <StackPanel   VerticalAlignment="Top"   >


                                            <StackPanel Name="stpPDF" Orientation="Vertical"    Drop="dropTheBomb" AllowDrop="True" 
                                                        Height="160" >


                                                <Border BorderBrush="Black"  Margin="5" BorderThickness="1"
                                                           Drop="dropTheBomb" AllowDrop="True"
                                                           Width="100" Height="90" Panel.ZIndex="2"
                   >
                                                    <TextBlock Padding="5" Margin="0,9,0,-1">Drop PDF here</TextBlock>
                                                    <!--<Image Name="imgTiff" VerticalAlignment="Top"    Drop="dropTheBomb" AllowDrop="True"></Image>-->
                                                </Border>
                                                <TextBlock Name="tbFiledate" Padding="0" Width="98" />


                                                <Button x:Name="btnPDFaufrufen" Click="btnPDFaufrufen_Click"  Margin="5"
                                                           Panel.ZIndex="10" Visibility="Visible"
                                                           Height="30">PDF anzeigen</Button>
                                                <TextBlock Name="tbPDFvorhanden" Margin="5"/>

                                                <Button Name="btnProtokoll" Click="btnProtokoll_Click"    Background="LightGray" >Logfiles</Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>


                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="Black" BorderThickness="1" Margin="5"
                                Width="1075"
                                HorizontalAlignment="Left">

                            <StackPanel Name="spBL"  Width="1340">
                                <StackPanel Orientation="Horizontal" Width="1340">

                                    <StackPanel Orientation="Vertical" >
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="left" >


                                            <Button Name="btnZumGIS" Click="btnZumGIS_Click" 
                                                    Visibility="Collapsed"
                                                      Content="Flurstück im GIS" Width="100"    
                                                       Height="20"  Padding="-2" Margin="5"  
                                                      ToolTip="Zeigt das Flurstück im GIS"
                                                      HorizontalAlignment="Right"/>
                                            <Button Name="btnZumGISOBJ" Click="btnZumGISOBJ_Click" Visibility="Visible"
                                                      Content="Baulast im GIS" Width="100"    
                                         Height="20"  Padding="-2" Margin="5" HorizontalAlignment="Right"
                                                      ToolTip="Zeigt die Baulast im GIS. Diese Möglichkeit geht nur dann wenn das Objekt bereits erfasst wurde!"/>
                                            <Button Name="btnUebertragMetadaten" IsEnabled="true" Click="btnUebertragMetadaten_Click"
              Margin="5"  Height="20" Width="100">
                                                Übertrag</Button>
                                            <Button Name="btnEigentuemerGIS" Click="btnEigentuemerGIS_Click" Margin="5" Height="20"
              Width="100" Visibility="Collapsed"
              ToolTip="Zeigt die Eigentümerdaten entsprechend der Flurstücksangaben im GIS">
                                                Eigentümer</Button>
                                            <TextBlock Name="tbanzahlobjgis" Padding="15" Margin="2" 
                                              FontStyle="Normal"   ></TextBlock>

                                            <TextBlock Margin="2" Padding="15"   FontStyle="Normal" FontFamily="Arial Black"> G I S</TextBlock>
                                            <!--<Button x:Name="btndigit" Click="btndigit_Click" Content=" digitalisieren "
              Background="red" Height="15" 
              Padding="-2" Margin="5" HorizontalAlignment="Right"/>-->

                                        </StackPanel>
                                        <DataGrid  x:Name="dgAusGIS"   ItemsSource="{Binding ''}"    Margin="0"                                             
                                                RowStyle="{StaticResource dgRowStyleRB}"                                              
                                                ColumnHeaderStyle="{StaticResource dgHeaderStyle}"    
                                            Width="930"    Height="160"
                                             HorizontalAlignment="Left"
     >
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Gemarkung"      Binding="{Binding gemarkungstext}"     />
                                                <!--<DataGridTextColumn Header="gemnr"      Binding="{Binding gemcode}"     />-->
                                                <DataGridTextColumn Header="Flur"  Binding="{Binding flur}" />
                                                <!--<DataGridTextColumn Header="Zähler"   Binding="{Binding zaehler}" />
          <DataGridTextColumn Header="Nenner"   Binding="{Binding nenner}" />-->
                                                <DataGridTextColumn Header=""  Binding="{Binding fstueckKombi}" />
                                                <DataGridTextColumn Header="BNr"  Binding="{Binding gebucht}" />
                                                <DataGridTextColumn Header="Gemeinde"    Binding="{Binding gemeindename}" />
                                                <DataGridTextColumn Header="Info"    Binding="{Binding fsgml}" />
                                                <DataGridTextColumn Header="az"    Binding="{Binding AzOG}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>

                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <StackPanel  Height="250"  HorizontalAlignment="Left"
                                     Background="AliceBlue"
                                     Width="1077">


                            <TextBlock Width="100" Margin="5" Padding="5">Eigentümer:</TextBlock>
                            <StackPanel Orientation="Horizontal">

                                <TextBox Name="tbEigentuemer"
 Width="930" Height="200" VerticalScrollBarVisibility="Auto"
                                    Margin="0" TextWrapping="Wrap" 
                                    AcceptsReturn="True" AcceptsTab="True" />
                                <StackPanel>
                                    <Button Name="btnEigentümerclip" Click="btnEigentümerclip_Click" 
                          Margin="1" Width="140" HorizontalAlignment="Left"
                >in Zwischenablage</Button>
                                    <Button Name="btnMakeworddok" Click="btnMakeworddok_Click"   HorizontalAlignment="Left"
                        Margin="1" Width="140">
                                        Word
                                    </Button>
                                    <Button Name="btnBestand" Click="btnBestand_Click" Content="Bestandsliste (mehrfach)" 
                                            Margin="0"  IsEnabled="True" Width="140"
                                            ToolTip="Mit laufender Nummer. Vollständig."
                                            />
                                    <Button Name="btnBestandPur" Click="btnBestandPur_Click" Content="Bestandsliste (einfach)" 
                                            Margin="0"  IsEnabled="True" Width="140"
                                            ToolTip="Jede Baulast eine Zeile!"
                                            />
                                    <!--<Button Name="btnBestand" Click="btnBestandPur_Click" Content="Bestandsliste (pur)" 
                                               Margin="0"  IsEnabled="True" Width="130"
                                               />-->
                                    <Button Name="btnpdfexist" Click="btnPDFExistenzpruefen_Click" Content="Existieren die PDFs ?" Foreground="Red" ToolTip="Prüft ob die PDFs entsprechend der Flurstücksangaben im PROBAUG vorhanden sind. Achtung! dauert ewig und 3 tage "
                                            Margin="0"  IsEnabled="True" Width="140"
                                            />
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </StackPanel>

                 
                  
                </StackPanel>
            </TabItem>
            <TabItem Header="BaulastDokument (.TIFF)" IsEnabled="False" Visibility="Collapsed">
                <DockPanel >
                    <StackPanel>
                        <StackPanel  Orientation="Horizontal" Margin="5"
                                     Visibility="Collapsed">
                            <TextBlock Width="100" Margin="5">Tiffdatei:</TextBlock>
                            <TextBox Name="tbtiffdatei" Width="660"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="5">


                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
