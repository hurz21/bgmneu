<Window x:Class="winHaupt"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:bgm" AllowDrop="True"
        mc:Ignorable="d" Left="1" WindowStyle="ToolWindow"    Drop="Window_Drop"
        Title="BGM" Height="536" Width="187" Background="Beige" >
    <DockPanel Margin="5">
        <StackPanel Orientation="Vertical">
            <StackPanel Margin="5" Width="145" Name="stpAdminOnly" Background="LightGray">
                <Button Name="btnNeu" Click="btnNeu_Click" Content="Neu" Margin="5" 
                    IsEnabled="False" Visibility="Collapsed"/>
                <GroupBox Name="grpBaulasten" Background="LightGray" Height="145">
                    <StackPanel>

                        <Button Name="btnEdit" Click="btnEdit_Click" Content="zu Baulast" 
                            IsDefault="True" Margin="5" 
                             Drop="Window_Drop" AllowDrop="True"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock >Nr:</TextBlock>
                            <TextBox x:Name="tbblnr" HorizontalAlignment="Center"
                                 Width="70" >
                            </TextBox>
                        </StackPanel>
                        <Button Name="btnBestand" Click="btnBestand_Click" Content="Bestandsliste" 
                                Margin="5"
                                IsEnabled="False"/>
                        <Button x:Name="btnPDFTool" Click="btnPDFTool_Click" Content="Werkzeuge"
                                IsEnabled="False" Margin="5"/>

                    </StackPanel>
                </GroupBox>

            </StackPanel>
            <StackPanel IsEnabled="True" Visibility="Collapsed">
                <Button Name="btngetFlurstück" Margin="5" Click="btngetFlurstueck_Click"  >Flurstück wählen

                </Button>
                <TextBlock Name="tbFlurstueckDisplay" Margin="5" Foreground="Gray" 
                           Background="White" Height="40" TextWrapping="Wrap">
                bitte Flurstück wählen
                </TextBlock>
                <Button Name="btnEigentuemer"  Margin="5" Click="btnEigentuemer_Click" IsEnabled="False" >Eigentümer für Flurstück

                </Button>
                <Button Name="btnRevers" Margin="5" IsEnabled="False" Visibility="Collapsed">Flurstücke zu Eigentümer

                </Button>
                <GroupBox Name="gbBaulast" BorderThickness="3" BorderBrush="Black">
                    <StackPanel>
                        
                    <Button Name="btnBaulast4FST" Margin="5" Click="btnBaulast4FST_Click" 
                        IsEnabled="False" Visibility="Collapsed">Baulast zum Flurstück
                    </Button>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                        <TextBlock  >Baulast-Nr:</TextBlock>
                            <TextBox x:Name="tbBaulast2" HorizontalAlignment="Center"
                                 Width="70" TextChanged="tbBaulast2_TextChanged" >

                            </TextBox>
                    </StackPanel>
                    <Button Name="btnBaulastdisplay"  Click="btnBaulastdisplay_Click"
                        IsEnabled="False">Baulast anzeigen

                    </Button>
                
                    </StackPanel>
                </GroupBox>

            </StackPanel>
            <Button Name="btnShowPDF1" Click="btnShowPDF_Click" Visibility="Visible" 
                    IsEnabled="True" Margin="5,5,5,0" ToolTip="zeigt unmittelbar die PDF-Datei der Baulast an">
                Baulast als PDF
            </Button>
            <Button Name="btnBaulastImGIS" Click="btnBaulastImGIS_Click" Content="Baulast im GIS" Margin="5,0,5,5"
                    ToolTip="zeigt unmittelbar die Baulast im GIS an"/>
            <Button Name="btnGIS" Click="btnGIS_Click" Content="GIS" Margin="5,9,5,5" Visibility="Collapsed"
                    ToolTip="zeigt unmittelbar die PDF-Datei der Baulast an"/>
          

            <Button Name="btnbplan"   Click="btnbplan_Click" Visibility="Collapsed" Margin="5">Bebauungspläne            </Button>
            <GroupBox x:Name="grpEigentuemer" Height="200" Width="170" Header="Eigentümer"
                      Background="LightGray">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Width="75">Gemarkung: </Label>
                           <ComboBox x:Name="cmbGemarkungen" HorizontalAlignment="Left" 
                                    Height="25" Width="80"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Width="75">Flur:</Label>
                        <TextBox Name="tbFlur" Width="80"></TextBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Width="75">Zähler:</Label>
                        <TextBox Name="tbZaehler" Width="80"></TextBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Width="75">Nenner:</Label>
                        <TextBox Name="tbnenner" Width="80"></TextBox>
                    </StackPanel>
                    <Button x:Name="btnsucheeigentumer" Click="btnsucheeigentumer_Click"
                            Margin="0,5,0,0">Word-Datei</Button>
                    <Button x:Name="btngis4fst" Click="btngis4fst_click">im GIS</Button>


                </StackPanel>
                
           

            </GroupBox>
        </StackPanel>
    </DockPanel>
</Window>
